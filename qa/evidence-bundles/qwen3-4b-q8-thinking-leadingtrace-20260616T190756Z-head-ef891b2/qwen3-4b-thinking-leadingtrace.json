    "engine": "llama.cpp",
    "version": "b9430 (d48a56eff)",
    "flags": "-ngl 0 -ctk f32 -ctv f32 -fa off --no-repack -c 16384",
    "url": "http://127.0.0.1:8090",
    "fed": "the bare-assistant thinking-enabled ChatML prompt via /completion"
  },
  "camelid": {
    "url": "http://127.0.0.1:8185",
    "model_id": "Qwen3 4B Instruct",
    "api": "/v1/chat/completions with camelid_enable_thinking:true",
    "backend": "cpu_reference (CAMELID_METAL_RESIDENT_*=0)",
    "renderer": "render_qwen3_chatml_prompt(messages, enable_thinking=true)"
  },
  "n": 256,
  "all_probes_engage_thinking": true,
  "all_probes_match_at_5": true,
  "immediate_divergence_blocker": false,
  "leading_trace_parity_envelope_tokens": {
